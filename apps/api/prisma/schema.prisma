generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String            @id @default(uuid())
  username       String            @unique
  email          String            @unique
  password       String
  college        String
  department     Department
  graduationYear Int
  currentSem     Semester
  profileImage   String?
  bio            String?
  linkedin       String?
  github         String?
  role           Role              @default(STUDENT)
  verified       Boolean           @default(false)
  status         UserStatus        @default(PENDING)
  employeeId     String?
  designation    String?
  idCardImage    String?
  reputation     Int               @default(0)
  uploadsCount   Int               @default(0)
  isSenior       Boolean           @default(false)
  lastLogin      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  deletedAt      DateTime?
  aiSearchLogs   AISearchLog[]
  bookmarks      Bookmark[]
  comments       Comment[]
  downloads      DownloadHistory[]
  notifications  Notification[]
  ratings        Rating[]
  resources      Resource[]
  searchHistory  SearchHistory[]
  messages  Message[]

  @@index([college])
  @@index([department])
}

model StaffRecord {
  id           String @id @default(uuid())
  employeeId   String @unique
  name         String
  email        String
  department   String
  designation  String
  college      String
  isActive     Boolean @default(true)
}

model Subject {
  id          String     @id @default(uuid())
  name        String
  code        String
  department  Department
  semester    Semester
  description String?
  icon        String?
  createdAt   DateTime   @default(now())
  resources   Resource[]

  @@unique([code, department])
}

model Resource {
  id            String            @id @default(uuid())
  title         String
  description   String?
  fileUrl       String
  fileType      FileType
  mimeType      String?
  fileSize      Int?
  contentText   String?
  type          ResourceType
  semester      Semester
  department    Department
  isTeacherUpload Boolean         @default(false)
  unit          Int?
  year          Int?
  syllabusMatch Boolean           @default(true)
  avgRating     Float             @default(0)
  viewCount     Int               @default(0)
  downloadCount Int               @default(0)
  isAdminPick   Boolean           @default(false)
  status        ResourceStatus    @default(PENDING)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  deletedAt     DateTime?
  subjectId     String
  userId        String
  examType      ExamType?
  publicId      String
  examDate      String?
  bookmarks     Bookmark[]
  comments      Comment[]
  downloads     DownloadHistory[]
  ratings       Rating[]
  subject       Subject           @relation(fields: [subjectId], references: [id])
  uploadedBy    User              @relation(fields: [userId], references: [id])
  tags          ResourceTag[]

  @@index([subjectId])
  @@index([department, semester])
  @@index([type])
  @@index([avgRating])
}

model Tag {
  id        String        @id @default(uuid())
  name      String        @unique
  resources ResourceTag[]
}

model ResourceTag {
  resourceId String
  tagId      String
  resource   Resource @relation(fields: [resourceId], references: [id])
  tag        Tag      @relation(fields: [tagId], references: [id])

  @@id([resourceId, tagId])
}

model Rating {
  id         String   @id @default(uuid())
  score      Int
  review     String?
  createdAt  DateTime @default(now())
  userId     String
  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, resourceId])
}

model Bookmark {
  id         String   @id @default(uuid())
  createdAt  DateTime @default(now())
  userId     String
  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, resourceId])
}

model Comment {
  id         String   @id @default(uuid())
  text       String
  createdAt  DateTime @default(now())
  userId     String
  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id])
  user       User     @relation(fields: [userId], references: [id])
}

model DownloadHistory {
  id         String   @id @default(uuid())
  createdAt  DateTime @default(now())
  userId     String
  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id])
  user       User     @relation(fields: [userId], references: [id])
}

model SearchHistory {
  id        String   @id @default(uuid())
  query     String
  filters   Json?
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}

model AISearchLog {
  id        String   @id @default(uuid())
  query     String
  subjectId String
  response  String?
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}

model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Department {
  CSE
  ECE
  EEE
  MECH
  CIVIL
  IT
}

enum Semester {
  SEM1
  SEM2
  SEM3
  SEM4
  SEM5
  SEM6
  SEM7
  SEM8
}

enum ResourceType {
  NOTES
  PPT
  PAST_PAPER
  TEXTBOOK
  LAB_MANUAL
  SYLLABUS
  VIDEO
  LINK
  OTHER
}

enum FileType {
  PDF
  PPT
  DOC
  VIDEO
  LINK
}

enum ExamType {
  MID_SEM
  END_SEM
}

enum ResourceStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

enum NotificationType {
  RESOURCE_APPROVED
  RESOURCE_REJECTED
  COMMENT_REPLY
  NEW_RESOURCE
  SYSTEM
}

model Room {
  id        String   @id @default(uuid())
  name      String
  subjectId String?
  createdAt DateTime @default(now())
  messages  Message[]
}

model Message {
  id        String   @id @default(uuid())
  text      String?
  imageUrl  String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  room      Room     @relation(fields: [roomId], references: [id])
  roomId    String

  @@index([roomId, createdAt])
}